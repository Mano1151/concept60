rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User-owned search history: only the authenticated user may read/write their documents
    match /users/{userId}/searchHistory/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Optional: secure other per-user documents
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow users to check if they are an admin
    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }
  }
}
