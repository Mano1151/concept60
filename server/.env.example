PORT=5000

# AI Provider: ollama | anthropic | openai | gemini | groq | qwen
AI_PROVIDER=qwen

# Ollama (local model - no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Cloud providers (optional fallbacks)
ANTHROPIC_API_KEY=your_api_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5

# Firebase
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY=your_private_key

# ── RAG Pipeline ──────────────────────────────────────────────────────────
# Pinecone vector database (https://www.pinecone.io)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=concept60-dsa

# Python embedding microservice (sentence-transformers/all-MiniLM-L6-v2)
EMBED_SERVICE_URL=http://localhost:8001
EMBED_TIMEOUT_MS=5000

# RAG retrieval config
RAG_TOP_K=5
RAG_RELEVANCE_THRESHOLD=0.25

# Qwen model via Groq (used when AI_PROVIDER=qwen)
QWEN_MODEL=qwen-qwq-32b
